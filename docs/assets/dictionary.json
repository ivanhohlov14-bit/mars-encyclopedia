  "particles": {
    "nu": { "type": "tense_past", "placement": "after_verb", "desc": "прошедшее время" },
    "shu": { "type": "tense_future", "placement": "after_verb", "desc": "будущее время" },
    "ān": { "type": "negation", "placement": "after_verb", "desc": "отрицание (перед shu для будущего)" },
    "kha": { "type": "question", "placement": "end_of_sentence", "desc": "вопросительная частица" },
    "kha_subj": { "type": "subjunctive", "placement": "before_verb", "desc": "сослагательное наклонение" },
    "rak": { "type": "passive", "placement": "after_verb", "desc": "пассивный залог" },
    "thu": { "type": "reported", "placement": "end_of_sentence", "desc": "косвенная речь (так говорят)" },
    "na": { "type": "genitive", "placement": "after_possessor", "desc": "родительный падеж (of)" },
    "la_emph": { "type": "emphasis", "placement": "after_subject", "desc": "эмфаза подлежащего" },
    "ra_emph": { "type": "emphasis", "placement": "after_object", "desc": "эмфаза дополнения" }
  },

  "suffixes": {
    "ān": { "type": "plural", "attaches_to": "noun, adj", "rule": "после согласной -ān, после гласной -zān", "desc": "множественное число" },
    "an": { "type": "possessive", "person": "1sg", "desc": "мой" },
    "tan": { "type": "possessive", "person": "2sg", "desc": "твой" },
    "lan": { "type": "possessive", "person": "3sg", "desc": "его/её" },
    "ānān": { "type": "possessive", "person": "1pl", "desc": "наш" },
    "tānān": { "type": "possessive", "person": "2pl", "desc": "ваш" },
    "lānān": { "type": "possessive", "person": "3pl", "desc": "их" },
    "xan": { "type": "modal", "meaning": "can", "desc": "могу, умею" },
    "shar": { "type": "modal", "meaning": "want", "desc": "хочу" },
    "mun": { "type": "modal", "meaning": "must", "desc": "должен, обязан" },
    "kha": { "type": "comparative", "attaches_to": "adj", "desc": "сравнительная степень (суффикс -kha)" },
    "kha_pre": { "type": "superlative", "attaches_to": "adj", "desc": "превосходная степень (приставка kha-)" },
    "sen": { "type": "abstract", "attaches_to": "verb/noun", "desc": "место действия (абстрактное сущ-ное)" },
    "mar": { "type": "abstract", "attaches_to": "adj", "desc": "качество/состояние" },
    "lān": { "type": "abstract", "attaches_to": "verb", "desc": "результат/память о действии" },
    "khō": { "type": "abstract", "attaches_to": "noun", "desc": "процесс/энергия" },
    "ur": { "type": "participle", "voice": "active", "desc": "активное причастие (-ur)" },
    "rak_pass": { "type": "participle", "voice": "passive", "desc": "пассивное причастие (-rak)" },
    "ta": { "type": "gerund", "aspect": "simultaneous", "desc": "деепричастие (одновременность)" },
    "nu_ta": { "type": "gerund", "aspect": "prior", "desc": "деепричастие (предшествование)" },
    "ra_evid": { "type": "evidential", "source": "direct", "desc": "прямое наблюдение" },
    "ma_evid": { "type": "evidential", "source": "hearsay", "desc": "со слов других" },
    "la_evid": { "type": "evidential", "source": "inference", "desc": "умозаключение (должно быть)" },
    "tha_evid": { "type": "evidential", "source": "sacred", "desc": "сакральная истина (откровение)" }
  },

